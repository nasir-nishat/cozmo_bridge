{
  "name": "workspace",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node src/index.ts",
    "prod": "cross-env NODE_ENV=production ts-node src/index.ts",
    "build": "tsc && xcopy /Y src\\config\\*.json dist\\config\\ && xcopy /Y src\\data\\*.json dist\\data\\",
    "start": "node dist/index.js",
    "tunnel": "cloudflared tunnel --config cloudflared/config.yml run",
    "health": "powershell -ExecutionPolicy Bypass -File ./scripts/health-check.ps1",
    "health:local": "powershell -ExecutionPolicy Bypass -File ./scripts/health-check.ps1 -SkipWebhookTest",
    "mode:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/switch-mode.ps1 -Mode dev",
    "mode:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/switch-mode.ps1 -Mode prod",
    "patch:wechat": "powershell -ExecutionPolicy Bypass -File ./scripts/patch-wechatferry.ps1",
    "downgrade:wechat": "powershell -ExecutionPolicy Bypass -File ./scripts/downgrade-wechat.ps1",
    "knowledge:build": "node scripts/build-property-knowledge.mjs && node scripts/sanitize-knowledge.mjs",
    "knowledge:sanitize": "node scripts/sanitize-knowledge.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@supabase/supabase-js": "^2.106.2",
    "@types/node-cron": "^3.0.11",
    "@wechatferry/agent": "^0.0.26",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.15.1",
    "body-parser": "^2.2.2",
    "codex": "^0.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "input": "^1.0.1",
    "node-cron": "^4.2.1",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.0",
    "qrcode-terminal": "^0.12.0",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "@types/qrcode-terminal": "^0.12.2",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
