# Runtime mode
NODE_ENV=development
APP_MODE=dev

# Alert routing
SEND_JANDI_IN_DEV=false
USE_TEST_JANDI_WEBHOOK=false
LINE_USE_TEST_JANDI_WEBHOOK=false

# Polling and detection
NOTE_POLL_INTERVAL_MS=1200000
MESSAGE_HISTORY_FALLBACK_ENABLED=true
MESSAGE_HISTORY_CONTEXT_SIZE=10
LINE_HISTORY_FALLBACK_ENABLED=true
LINE_HISTORY_CONTEXT_SIZE=10

# Booking fallback
BOOKING_FALLBACK_ENABLED=false
BOOKING_FALLBACK_LOOKBACK_MS=28800000

# Platform toggles
ENABLE_WHATSAPP=true
ENABLE_LINE=false
ENABLE_KAKAO=false

# Group creation safety
GROUP_CREATION_REQUIRE_ALLOWLIST=true
GROUP_CREATION_LEAD_ALLOWLIST=
GROUP_CREATION_PROPERTY_ALLOWLIST=
FORCE_DEV_GROUP_MEMBERS=false

# LINE / Evolution optional overrides
LINE_BUSINESS_CARD_IMAGE_URL=
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=cozmo
EVOLUTION_API_KEY=
